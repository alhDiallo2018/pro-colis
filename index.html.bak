<div class="toast" id="toast"></div>
<div class="nav" id="nav">
  <span onclick="go('splash')">Accueil</span><span class="sep">›</span>
  <span onclick="go('profil-google')">Google Sign-In</span><span class="sep">›</span>
  <span onclick="go('inscription-email')">Email/MDP</span><span class="sep">›</span>
  <span onclick="go('dashboard')">Dashboard</span><span class="sep">›</span>
  <span onclick="go('det-arrive')">Arrivée+📞</span><span class="sep">›</span>
  <span onclick="go('abonnement')">Abonnement</span>
</div>
<script>
const dark=['splash','confirm-colis','remis'];
let cur='splash';
function go(id){
  const p=document.getElementById(cur),n=document.getElementById(id);
  if(!n)return;
  if(p){p.classList.remove('active');p.classList.add('bk');setTimeout(()=>p.classList.remove('bk'),350);}
  n.classList.add('active');cur=id;
  document.getElementById('sb').style.color=dark.includes(id)?'white':'#0F2218';
  document.querySelectorAll('.nav span:not(.sep)').forEach(s=>{
    s.classList.remove('cur');
    if(s.getAttribute('onclick')&&s.getAttribute('onclick').includes("'"+id+"'"))s.classList.add('cur');
  });
}
function stab(id,el){
  document.querySelectorAll('#'+cur+' .ti').forEach(t=>t.classList.remove('active'));
  if(el)el.classList.add('active');go(id);
}
function toast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2500);
}
function ut(){const n=new Date(),h=n.getHours().toString().padStart(2,'0'),m=n.getMinutes().toString().padStart(2,'0');document.querySelectorAll('.time').forEach(e=>e.textContent=h+':'+m);}
ut();setInterval(ut,30000);
</script>
</body>
</html>
