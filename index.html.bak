<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>PRO COLIS v2</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{--green:#0B6E3A;--green-mid:#168A48;--green-light:#22A85A;--gold:#F5A623;--dark:#0A1A10;--surface:#F4FAF6;--surface2:#E8F5ED;--text:#0F2218;--text2:#4A6B55;--text3:#8BA898;--white:#FFF;--blue:#1565C0;--red:#E53935;}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{font-family:'Outfit',sans-serif;background:#0D1F14;min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:24px 16px 60px;}
.lbl{color:rgba(255,255,255,0.4);font-size:11px;letter-spacing:3px;text-transform:uppercase;margin-bottom:16px;font-family:'Space Mono';}
.phone{width:375px;min-height:812px;background:#fff;border-radius:44px;overflow:hidden;box-shadow:0 32px 80px rgba(0,0,0,0.6);position:relative;display:flex;flex-direction:column;}
.notch{position:absolute;top:0;left:50%;transform:translateX(-50%);width:120px;height:30px;background:var(--dark);border-radius:0 0 18px 18px;z-index:100;}
.sb{height:44px;padding:0 24px 6px;display:flex;align-items:flex-end;justify-content:space-between;position:relative;z-index:50;flex-shrink:0;}
.sb .time{font-size:13px;font-weight:600;}
.screens{flex:1;position:relative;overflow:hidden;}
.screen{position:absolute;inset:0;display:flex;flex-direction:column;opacity:0;pointer-events:none;transition:opacity .3s,transform .3s;transform:translateX(30px);overflow-y:auto;}
.screen.active{opacity:1;pointer-events:all;transform:translateX(0);}
.screen.bk{transform:translateX(-30px);}

/* SPLASH */
#splash{background:linear-gradient(160deg,var(--dark),var(--green) 60%,var(--green-light));align-items:center;justify-content:center;}
.slogo{width:100px;height:100px;background:rgba(255,255,255,0.12);border-radius:28px;display:flex;align-items:center;justify-content:center;font-size:48px;margin-bottom:24px;border:2px solid rgba(255,255,255,0.2);animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(245,166,35,0.4);}50%{box-shadow:0 0 0 20px rgba(245,166,35,0);}}
.stitle{font-size:36px;font-weight:800;color:#fff;margin-bottom:8px;}
.stitle span{color:var(--gold);}
.ssub{font-size:14px;color:rgba(255,255,255,0.6);text-align:center;margin-bottom:48px;line-height:1.5;padding:0 32px;}

/* Auth buttons */
.auth-btns{display:flex;flex-direction:column;gap:12px;width:100%;padding:0 24px;}
.btn-google{background:#fff;color:#3c4043;font-family:'Outfit';font-size:15px;font-weight:700;border:none;border-radius:14px;padding:14px 24px;cursor:pointer;box-shadow:0 4px 16px rgba(0,0,0,0.2);display:flex;align-items:center;justify-content:center;gap:12px;transition:all .2s;}
.btn-google:active{transform:scale(0.98);}
.google-icon{width:22px;height:22px;background:linear-gradient(135deg,#4285F4,#EA4335,#FBBC04,#34A853);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:900;color:white;flex-shrink:0;}
.divider-auth{display:flex;align-items:center;gap:12px;padding:0 8px;}
.divider-auth span{font-size:12px;color:rgba(255,255,255,0.4);white-space:nowrap;}
.divider-auth::before,.divider-auth::after{content:'';flex:1;height:1px;background:rgba(255,255,255,0.2);}
.btn-email{background:rgba(255,255,255,0.12);color:white;font-family:'Outfit';font-size:15px;font-weight:600;border:1.5px solid rgba(255,255,255,0.25);border-radius:14px;padding:14px 24px;cursor:pointer;transition:all .2s;}
.btn-email:active{transform:scale(0.98);}

/* INSCRIPTION EMAIL */
#inscription-email{background:var(--white);}
.hdr{background:linear-gradient(135deg,var(--dark),var(--green));padding:60px 24px 24px;flex-shrink:0;}
.bbtn{width:36px;height:36px;background:rgba(255,255,255,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;margin-bottom:20px;border:none;color:white;}
.htitle{font-size:26px;font-weight:800;color:white;margin-bottom:6px;}
.hsub{font-size:13px;color:rgba(255,255,255,0.65);line-height:1.5;}
.body{flex:1;padding:24px;display:flex;flex-direction:column;gap:18px;}
.fg{display:flex;flex-direction:column;gap:8px;}
.fl{font-size:12px;font-weight:600;color:var(--text2);letter-spacing:.5px;text-transform:uppercase;}
.fi{background:var(--surface);border:2px solid transparent;border-radius:12px;padding:14px 16px;font-family:'Outfit';font-size:15px;color:var(--text);outline:none;width:100%;}
.fi:focus{border-color:var(--green-light);background:white;}
.fi::placeholder{color:var(--text3);}
.sel{background:var(--surface);border:2px solid transparent;border-radius:12px;padding:14px 16px;font-family:'Outfit';font-size:15px;color:var(--text);width:100%;outline:none;appearance:none;}
.btnp{background:var(--green);color:white;font-family:'Outfit';font-size:16px;font-weight:700;border:none;border-radius:16px;padding:16px;cursor:pointer;width:100%;box-shadow:0 6px 20px rgba(11,110,58,0.3);margin-top:auto;}

/* PROFIL GOOGLE */
#profil-google{background:var(--white);}
.google-profile-banner{background:linear-gradient(135deg,#4285F4,#34A853);border-radius:14px;padding:16px;display:flex;align-items:center;gap:14px;margin-bottom:20px;}
.gp-avatar{width:52px;height:52px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;border:2px solid rgba(255,255,255,0.3);}
.gp-info .gname{font-size:15px;font-weight:700;color:white;}
.gp-info .gemail{font-size:11px;color:rgba(255,255,255,0.75);margin-top:2px;font-family:'Space Mono';}
.gp-badge{background:rgba(255,255,255,0.2);color:white;font-size:10px;font-weight:700;padding:4px 10px;border-radius:20px;flex-shrink:0;border:1px solid rgba(255,255,255,0.3);}

/* DASHBOARD */
#dashboard{background:var(--surface);}
.dhdr{background:linear-gradient(135deg,var(--dark),var(--green));padding:56px 24px 24px;flex-shrink:0;}
.dgreet{font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:4px;}
.dname{font-size:22px;font-weight:800;color:white;margin-bottom:20px;}
.dname span{color:var(--gold);}
.srow{display:flex;gap:12px;}
.stat{flex:1;background:rgba(255,255,255,.12);border-radius:14px;padding:14px;border:1px solid rgba(255,255,255,.15);}
.snum{font-size:26px;font-weight:800;color:white;}
.slbl{font-size:11px;color:rgba(255,255,255,0.6);margin-top:2px;}
.stat.gd .snum{color:var(--gold);}
.dbody{flex:1;padding:20px 24px;overflow-y:auto;}
.sectit{font-size:13px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin-bottom:14px;}
.btnew{background:var(--green);color:white;border:none;border-radius:18px;padding:18px 24px;width:100%;display:flex;align-items:center;justify-content:space-between;cursor:pointer;margin-bottom:24px;box-shadow:0 8px 32px rgba(11,110,58,.13);}
.abo-ban{background:linear-gradient(135deg,var(--green),var(--green-light));border-radius:16px;padding:18px;margin-bottom:20px;display:flex;align-items:center;gap:14px;cursor:pointer;}
.abo-bdg{background:var(--gold);color:var(--dark);font-size:10px;font-weight:800;padding:4px 10px;border-radius:20px;white-space:nowrap;flex-shrink:0;}

/* CARDS */
.cc{background:white;border-radius:16px;padding:16px;margin-bottom:12px;box-shadow:0 2px 12px rgba(0,0,0,.06);cursor:pointer;display:flex;align-items:center;gap:14px;}
.cth{width:52px;height:52px;border-radius:12px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.ci{flex:1;min-width:0;}
.cid{font-size:10px;font-weight:700;color:var(--text3);letter-spacing:1px;font-family:'Space Mono';}
.cdest{font-size:14px;font-weight:700;color:var(--text);margin:2px 0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cdesc{font-size:12px;color:var(--text2);}
.badge{font-size:10px;font-weight:700;padding:4px 10px;border-radius:20px;white-space:nowrap;flex-shrink:0;}
.bt{background:rgba(21,101,192,.1);color:var(--blue);}
.ba{background:rgba(245,166,35,.15);color:#B8760A;}
.br{background:rgba(11,110,58,.1);color:var(--green);}

/* TAB */
.tabs{display:flex;background:white;border-top:1px solid var(--surface2);padding:8px 0 20px;flex-shrink:0;}
.ti{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;padding:8px 0;cursor:pointer;border:none;background:none;}
.ticon{font-size:22px;}
.tlbl{font-size:10px;font-weight:600;color:var(--text3);font-family:'Outfit';}
.ti.active .tlbl{color:var(--green);}
.ti.active .ticon{transform:scale(1.1);}

/* FORMS NOUVEAU COLIS */
.phw{display:flex;gap:10px;}
.php{background:var(--surface);border:2px solid transparent;border-radius:12px;padding:14px 12px;font-size:15px;font-weight:600;color:var(--text2);white-space:nowrap;flex-shrink:0;}

/* DETAIL */
.dhdrdet{background:linear-gradient(135deg,var(--dark),var(--green));padding:56px 24px 28px;flex-shrink:0;}
.did{font-size:11px;font-family:'Space Mono';color:rgba(255,255,255,.5);margin-bottom:6px;}
.dtit{font-size:22px;font-weight:800;color:white;margin-bottom:12px;}
.dst{display:inline-flex;align-items:center;gap:8px;background:var(--gold);color:var(--dark);font-size:12px;font-weight:700;padding:6px 14px;border-radius:20px;}
.dbody2{flex:1;padding:20px 24px;overflow-y:auto;}
.dphoto{width:100%;height:160px;background:linear-gradient(135deg,var(--surface2),var(--surface));border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:56px;margin-bottom:18px;}
.ic{background:white;border-radius:16px;padding:16px;margin-bottom:14px;box-shadow:0 2px 12px rgba(0,0,0,.05);}
.ict{font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;}
.ir{display:flex;justify-content:space-between;align-items:center;padding:8px 0;}
.ir+.ir{border-top:1px solid var(--surface2);}
.ik{font-size:13px;color:var(--text2);}
.iv{font-size:13px;font-weight:600;color:var(--text);text-align:right;}
.csec{background:white;border-radius:16px;padding:16px;margin-bottom:14px;box-shadow:0 2px 12px rgba(0,0,0,.05);}
.ctit{font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;}
.crow{display:flex;gap:10px;margin-bottom:10px;}
.cbtn{flex:1;border:none;border-radius:12px;padding:13px 10px;font-family:'Outfit';font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;}
.cbtn:active{transform:scale(.97);}
.cbtn.sms{background:var(--gold);color:var(--dark);}
.cbtn.call{background:var(--blue);color:white;}
.cbtn.exp{background:#FFF3E0;color:#E65100;border:1.5px solid #FFCC80;}
.abtn{width:100%;border:none;border-radius:14px;padding:15px;font-family:'Outfit';font-size:14px;font-weight:700;cursor:pointer;margin-bottom:10px;display:flex;align-items:center;justify-content:center;gap:8px;}
.abtn.remis{background:var(--green);color:white;box-shadow:0 6px 20px rgba(11,110,58,.3);}
.abtn.out{background:transparent;border:2px solid var(--surface2);color:var(--text2);}

/* ABO */
.plan{border-radius:18px;padding:20px;margin-bottom:16px;}
.plan.free{background:var(--surface2);border:2px solid var(--green-light);}
.plan.pro{background:linear-gradient(135deg,var(--green),var(--green-light));box-shadow:0 8px 24px rgba(11,110,58,.3);}

/* PROFIL */
.phdr2{background:linear-gradient(135deg,var(--dark),var(--green));padding:56px 24px 40px;display:flex;flex-direction:column;align-items:center;flex-shrink:0;}
.av{width:80px;height:80px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-size:36px;margin-bottom:14px;border:3px solid rgba(255,255,255,.2);}
.pcard{background:white;border-radius:16px;overflow:hidden;margin-bottom:16px;box-shadow:0 2px 12px rgba(0,0,0,.05);}
.pi{display:flex;align-items:center;gap:14px;padding:16px;cursor:pointer;border-bottom:1px solid var(--surface2);}
.pi:last-child{border-bottom:none;}
.pi.abo{background:linear-gradient(135deg,rgba(11,110,58,.06),rgba(34,168,90,.04));}
.pi.gauth{background:linear-gradient(135deg,rgba(66,133,244,.06),rgba(52,168,83,.04));}

/* TOAST */
.toast{position:fixed;bottom:100px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--dark);color:white;font-family:'Outfit';font-size:13px;font-weight:600;padding:12px 24px;border-radius:40px;opacity:0;transition:all .3s;white-space:nowrap;z-index:9999;pointer-events:none;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* NAV */
.nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);background:rgba(13,31,20,.9);backdrop-filter:blur(12px);border-radius:20px 20px 0 0;padding:10px 20px 6px;display:flex;gap:6px;font-size:10px;color:rgba(255,255,255,.4);font-family:'Space Mono';z-index:1000;width:375px;justify-content:center;flex-wrap:wrap;}
.nav span{cursor:pointer;transition:color .2s;}
.nav span:hover{color:rgba(255,255,255,.8);}
.nav .sep{color:rgba(255,255,255,.2);}
.nav .cur{color:var(--gold);}
@media(max-width:400px){.phone{width:100%;border-radius:0;min-height:100vh;}.nav{width:100%;}body{padding:0;}.lbl{display:none;}}
</style>
</head>
<body>
<div class="lbl">PRO COLIS v2 — Prototype Interactif</div>
<div class="phone">
<div class="notch"></div>
<div class="sb" id="sb" style="color:white;"><span class="time">9:41</span><span style="font-size:11px;display:flex;gap:5px;">▲▼ 5G 🔋</span></div>
<div class="screens">

<!-- SPLASH -->
<div class="screen active" id="splash" style="align-items:center;justify-content:center;">
  <div style="display:flex;flex-direction:column;align-items:center;padding:40px 24px;width:100%;">
    <div class="slogo">📦</div>
    <div class="stitle">PRO <span>COLIS</span></div>
    <div class="ssub">Gérez vos colis interurbains simplement et en toute confiance</div>
    <div class="auth-btns">
      <button class="btn-google" onclick="go('profil-google');toast('✅ Connecté avec Google !')">
        <div class="google-icon">G</div>
        Continuer avec Google
      </button>
      <div class="divider-auth"><span>ou</span></div>
      <button class="btn-email" onclick="go('inscription-email')">✉️ S'inscrire avec un email</button>
    </div>
    <div style="font-size:11px;color:rgba(255,255,255,0.35);margin-top:20px;text-align:center;padding:0 24px;">En vous connectant, vous acceptez les conditions d'utilisation de PRO COLIS</div>
  </div>
</div>

<!-- INSCRIPTION EMAIL -->
<div class="screen" id="inscription-email">
  <div class="hdr"><button class="bbtn" onclick="go('splash')">←</button><div class="htitle">Créer un compte</div><div class="hsub">Inscription avec votre adresse email</div></div>
  <div class="body">
    <div class="fg"><div class="fl">Prénom</div><input class="fi" placeholder="Ex: Mamadou"/></div>
    <div class="fg"><div class="fl">Nom</div><input class="fi" placeholder="Ex: Diallo"/></div>
    <div class="fg"><div class="fl">Adresse email</div><input class="fi" type="email" placeholder="exemple@gmail.com"/></div>
    <div class="fg"><div class="fl">Mot de passe</div><input class="fi" type="password" placeholder="Min. 8 caractères"/></div>
    <div class="fg">
      <div class="fl">Trajet habituel</div>
      <select class="sel"><option value="">Sélectionner</option><option>Dakar → Thiès</option><option>Dakar → Saint-Louis</option><option>Dakar → Ziguinchor</option><option>Dakar → Kaolack</option><option>Dakar → Tambacounda</option></select>
    </div>
    <div style="background:var(--surface2);border-radius:12px;padding:12px 14px;font-size:12px;color:var(--text2);">📧 Un email de vérification vous sera envoyé pour activer votre compte.</div>
    <button class="btnp" onclick="go('verif-email')">Créer mon compte →</button>
  </div>
</div>

<!-- VERIFICATION EMAIL -->
<div class="screen" id="verif-email">
  <div class="hdr"><button class="bbtn" onclick="go('inscription-email')">←</button><div class="htitle">Vérifiez votre email</div><div class="hsub">Un lien vous a été envoyé</div></div>
  <div class="body" style="align-items:center;">
    <div style="font-size:64px;margin-bottom:16px;">📧</div>
    <div style="font-size:16px;font-weight:700;color:var(--text);margin-bottom:8px;text-align:center;">Email envoyé !</div>
    <div style="font-size:13px;color:var(--text2);text-align:center;line-height:1.6;margin-bottom:32px;">Cliquez sur le lien dans l'email envoyé à <strong>mamadou.diallo@gmail.com</strong> pour activer votre compte.</div>
    <div style="background:var(--surface2);border-radius:16px;padding:20px;width:100%;margin-bottom:24px;">
      <div style="font-size:12px;color:var(--text2);margin-bottom:8px;">Vous n'avez pas reçu l'email ?</div>
      <div style="font-size:13px;color:var(--green);font-weight:600;cursor:pointer;" onclick="toast('📧 Email renvoyé !')">Renvoyer l'email de vérification</div>
    </div>
    <button class="btnp" onclick="go('dashboard')" style="width:100%;">J'ai vérifié mon email →</button>
  </div>
</div>

<!-- PROFIL GOOGLE (après connexion Google) -->
<div class="screen" id="profil-google">
  <div class="hdr"><div class="htitle" style="margin-top:16px;">Finaliser le profil</div><div class="hsub">Dernière étape avant de commencer</div></div>
  <div class="body">
    <div class="google-profile-banner">
      <div class="gp-avatar">🧑🏾</div>
      <div class="gp-info">
        <div class="gname">Mamadou Diallo</div>
        <div class="gemail">mamadou.diallo@gmail.com</div>
      </div>
      <div class="gp-badge">✓ Google</div>
    </div>
    <div style="background:var(--surface2);border-radius:12px;padding:12px 14px;font-size:12px;color:var(--text2);margin-bottom:4px;">✅ Nom et email récupérés automatiquement depuis votre compte Google.</div>
    <div class="fg">
      <div class="fl">Trajet habituel</div>
      <select class="sel"><option value="">Sélectionner votre trajet</option><option>Dakar → Thiès</option><option>Dakar → Saint-Louis</option><option>Dakar → Ziguinchor</option><option>Dakar → Kaolack</option><option>Dakar → Tambacounda</option><option>Thiès → Dakar</option></select>
    </div>
    <button class="btnp" onclick="go('dashboard');toast('🎉 Bienvenue sur PRO COLIS !')">Accéder à l'application →</button>
  </div>
</div>

<!-- DASHBOARD -->
<div class="screen" id="dashboard">
  <div class="dhdr">
    <div class="dgreet">Bonjour 👋</div>
    <div class="dname">Mamadou <span>Diallo</span></div>
    <div class="srow">
      <div class="stat"><div class="snum">12</div><div class="slbl">Total</div></div>
      <div class="stat gd"><div class="snum">3</div><div class="slbl">En transit</div></div>
      <div class="stat"><div class="snum">9</div><div class="slbl">Livrés</div></div>
    </div>
  </div>
  <div class="dbody">
    <div class="abo-ban" onclick="go('abonnement')">
      <div style="font-size:28px;">⭐</div>
      <div style="flex:1;"><div style="font-size:14px;font-weight:700;color:white;">Formule Gratuite active</div><div style="font-size:11px;color:rgba(255,255,255,.75);">Passez à Pro après la phase test</div></div>
      <div class="abo-bdg">GRATUIT</div>
    </div>
    <button class="btnew" onclick="go('nouveau-colis')">
      <div style="display:flex;align-items:center;gap:14px;"><div style="font-size:26px;">➕</div><div><div style="font-size:16px;font-weight:700;color:white;font-family:'Outfit';">Nouveau colis</div><div style="font-size:12px;color:rgba(255,255,255,.7);font-family:'Outfit';">Enregistrer un envoi</div></div></div>
      <div style="font-size:20px;color:rgba(255,255,255,.7);">›</div>
    </button>
    <div class="sectit">Colis récents</div>
    <div class="cc" onclick="go('det-transit')"><div class="cth">👕</div><div class="ci"><div class="cid">PC-20250501-0043</div><div class="cdest">Fatou Ndiaye · Thiès</div><div class="cdesc">Vêtements · 2 kg</div></div><div class="badge bt">Transit</div></div>
    <div class="cc" onclick="go('det-arrive')"><div class="cth">📄</div><div class="ci"><div class="cid">PC-20250430-0041</div><div class="cdest">Ibou Sow · Saint-Louis</div><div class="cdesc">Documents administratifs</div></div><div class="badge ba">Arrivé</div></div>
    <div class="cc"><div class="cth">🍱</div><div class="ci"><div class="cid">PC-20250428-0039</div><div class="cdest">Aïssatou Ba · Kaolack</div><div class="cdesc">Nourriture · 3 kg</div></div><div class="badge br">Remis ✓</div></div>
    <div style="height:80px;"></div>
  </div>
  <div class="tabs">
    <button class="ti active" onclick="stab('dashboard',this)"><span class="ticon">🏠</span><span class="tlbl">Accueil</span></button>
    <button class="ti" onclick="stab('nouveau-colis',this)"><span class="ticon">➕</span><span class="tlbl">Nouveau</span></button>
